<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CalendarDateText" parent="StarBody">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:shadowColor">@color/primary_star_light</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">2</item>
    </style>
    
    <style name="CalendarWeekDayText" parent="StarBody">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/primary_star</item>
        <item name="android:textStyle">bold</item>
        <item name="android:shadowColor">@color/primary_star_light</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">2</item>
    </style>
    
    <style name="CalendarMonthYearText" parent="StarBody">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/primary_star</item>
        <item name="android:textStyle">bold</item>
        <item name="android:shadowColor">@color/primary_star_light</item>
        <item name="android:shadowDx">2</item>
        <item name="android:shadowDy">2</item>
        <item name="android:shadowRadius">3</item>
    </style>
</resources>
