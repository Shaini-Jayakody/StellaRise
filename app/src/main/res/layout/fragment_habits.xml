<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true">

<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <!-- Calendar Section at Top -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/calendarCard"
        style="@style/StarCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="@drawable/topic_section_background"
            android:orientation="vertical"
            android:padding="12dp">

            <CalendarView
                android:id="@+id/habitsCalendarView"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:background="@color/background_light"
                android:dateTextAppearance="@style/CalendarDateText"
                android:focusedMonthDateColor="@color/primary_star"
                android:selectedDateVerticalBar="@drawable/calendar_star_selector"
                android:selectedWeekBackgroundColor="@color/primary_star_light"
                android:unfocusedMonthDateColor="@color/text_secondary"
                android:weekDayTextAppearance="@style/CalendarWeekDayText"
                android:weekNumberColor="@color/primary_star"
                android:weekSeparatorLineColor="@color/primary_star_light"
                android:scrollbars="vertical"
                android:fadeScrollbars="false"
                android:scrollbarStyle="outsideOverlay"
                android:scrollbarThumbVertical="@color/primary_star" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Header Image Below Calendar -->
    <ImageView
        android:id="@+id/headerImage"
        android:layout_width="200dp"
        android:layout_height="150dp"
        android:layout_marginTop="16dp"
        android:contentDescription="Habits Header"
        android:scaleType="centerCrop"
        android:src="@drawable/h_habbit"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/calendarCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Header Section -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/headerCard"
        style="@style/StarCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerImage">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/sparkle_purple"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Icon and Title Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/icon_background_gradient"
                    android:contentDescription="Habits Icon"
                    android:padding="18dp"
                    android:src="@drawable/habit_icon" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/habits_title"
                        android:textAppearance="@style/StarTitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/habits_subtitle"
                        android:textAppearance="@style/StarSubtitle" />

                </LinearLayout>

            </LinearLayout>

            <!-- Progress Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvCompletionRate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textAppearance="@style/StarTitle"
                        android:textColor="@color/design_default_color_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/completion_rate"
                        android:textAppearance="@style/StarBody"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvHabitsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/0"
                        android:textAppearance="@style/StarTitle"
                        android:textColor="@color/primary_star" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/today_progress"
                        android:textAppearance="@style/StarBody"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>

            </LinearLayout>


        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Star Completion Chart -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/starChartCard"
        style="@style/StarCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:layout_marginTop="8dp"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/headerCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/settings_header_image"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="⭐ Completion Stars"
                android:textAppearance="@style/StarBody"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/llStarChart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/star_chart_background"
                android:gravity="center_vertical"
                android:minHeight="48dp"
                android:orientation="horizontal"
                android:padding="12dp">

                <!-- Star 1 -->
                <TextView
                    android:id="@+id/star1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:alpha="0.3"
                    android:gravity="center"
                    android:text="⭐"
                    android:textSize="24sp" />

                <!-- Star 2 -->
                <TextView
                    android:id="@+id/star2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:alpha="0.3"
                    android:gravity="center"
                    android:text="⭐"
                    android:textSize="24sp" />

                <!-- Star 3 -->
                <TextView
                    android:id="@+id/star3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:alpha="0.3"
                    android:gravity="center"
                    android:text="⭐"
                    android:textSize="24sp" />

                <!-- Star 4 -->
                <TextView
                    android:id="@+id/star4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:alpha="0.3"
                    android:gravity="center"
                    android:text="⭐"
                    android:textSize="24sp" />

                <!-- Star 5 -->
                <TextView
                    android:id="@+id/star5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:alpha="0.3"
                    android:gravity="center"
                    android:text="⭐"
                    android:textSize="24sp" />

                <!-- Completion Text -->
                <TextView
                    android:id="@+id/tvStarCompletion"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical|end"
                    android:minHeight="24dp"
                    android:text="0/5 Stars"
                    android:textAppearance="@style/StarBody"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Habits List Container -->
    <LinearLayout
        android:id="@+id/llHabitsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="80dp"
        android:orientation="vertical"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/starChartCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Professional Add Habit Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddHabit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Add New Habit"
        android:src="@drawable/ic_add"
        android:elevation="8dp"
        app:backgroundTint="@color/primary_star"
        app:fabSize="normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/white" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/starChartCard"
        app:layout_constraintBottom_toTopOf="@id/fabAddHabit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐"
            android:textSize="64sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No habits yet"
            android:textAppearance="@style/StarTitle"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add your first habit to start tracking!"
            android:textAppearance="@style/StarBody"
            android:textColor="@color/text_secondary"
            android:gravity="center" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>

