<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/text_secondary"
                android:centerColor="@color/accent_silver"
                android:endColor="@color/white"
                android:angle="135" />
            <corners android:radius="16dp" />
            <stroke android:width="2dp" android:color="@color/primary_star_light" />
            <size android:height="56dp" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/white"
                android:centerColor="@color/accent_silver"
                android:endColor="@color/text_secondary"
                android:angle="135" />
            <corners android:radius="16dp" />
            <stroke android:width="3dp" android:color="@color/primary_star_light" />
            <size android:height="56dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/white"
                android:centerColor="@color/accent_silver"
                android:endColor="@color/text_secondary"
                android:angle="135" />
            <corners android:radius="16dp" />
            <stroke android:width="2dp" android:color="@color/primary_star_light" />
            <size android:height="56dp" />
        </shape>
    </item>
</selector>



